# Copy to .env and adjust. Everything has a sane local default; the cloud
# entries are written by scripts/cloud-run.sh from terraform outputs.

# --- the fairness box: identical for every proxy (hard invariant) -----------
PROXY_CPUS=1          # must match the thread knobs (nbthread/--concurrency/GOMAXPROCS).
                      # 1 by default: zoxy (libxev) is single-threaded with no
                      # knob, so one core each keeps the face-off per-core fair;
                      # raise it to probe multi-core scaling (zoxy stays at 1)
PROXY_MEM=512m
BACKEND_CPUS=4        # >=2x the proxy so the origin is never the bottleneck
BACKEND_MEM=1g

# --- the ramp: identical for every proxy (hard invariant) -------------------
# elapsed-time == offered-rate only holds if ALL proxies get the same ramp.
MAX_RATE=20000        # req/s at the end of the linear ramp; calibrate: a
                      # backend-direct run must saturate ABOVE this
RAMP_DURATION=8m
WARM_RATE=100         # 30s constant warmup, discarded by the report
MAX_VUS=400           # VU pool = the concurrency the ramp reaches at saturation
                      # (active VUs = arrival_rate x latency). 400 is the sweet
                      # spot from the concurrency sweep: every proxy peaks around
                      # 100-200 connections (~54k needs ~270 conns @ ~5ms), and
                      # 400 reaches that peak WITHOUT the high-concurrency collapse
                      # the sweep exposed. Well under zoxy's relay-buffer cap.
                      # Full throughput-vs-concurrency curve: make sweep-report
REQ_PATH=/1k          # /64 /1k /10k /100k

# --- run driver --------------------------------------------------------------
PROXIES="zoxy haproxy envoy traefik nginx pingora"   # all L4 TCP passthroughs
                                             # (zoxy's libxev build is L4-only);
                                             # zoxy needs a Linux docker host
                                             # with io_uring (native arch is
                                             # fine — no emulation). pingora is
                                             # a Rust binary we build on the
                                             # Pingora framework (proxies/pingora)
COOLDOWN=60           # seconds between proxies (TIME_WAIT drain, scrape settle)

# --- zoxy build ---------------------------------------------------------------
ZOXY_REF=main         # git ref of github.com/zoxy-io/zoxy to benchmark (the
                      # libxev rewrite: L4-only, single-threaded, no DNS)
#RELAY_BUFFERS_MAX=   # OPTIONAL benchmark override of zoxy's L4 concurrency cap
                      # (compile-time relay-buffer pool; upstream default 1024,
                      # patched at build time — the image tag records it).
                      # Lets MAX_VUS exceed 1024 to probe zoxy's ceiling. Hard
                      # ceiling ~1634: past it zoxy's io_uring ring budget assert
                      # fails to compile. Keep MAX_VUS < RELAY_BUFFERS_MAX.

# --- cloud only (filled by scripts/cloud-run.sh) ------------------------------
#PROM_TARGETS=cloud
#BACKEND_IP=10.10.0.20
#PROXY_IP=10.10.0.10
#PROXY_CPUSET=0-3
