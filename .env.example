# Copy to .env and adjust. Everything has a sane default; the cloud entries are
# written by scripts/zrk-bench.sh from terraform outputs.

# --- the fairness box: identical for every proxy (hard invariant) -----------
PROXY_CPUS=4          # must match the thread knobs (nbthread/--concurrency/
                      # GOMAXPROCS/worker_processes/threads). zoxy has no thread
                      # knob — it runs PROXY_CPUS worker processes sharing :8080
                      # via SO_REUSEPORT, each pinned to a core (ZOXY_WORKERS).
PROXY_MEM=512m
BACKEND_CPUS=4        # >=2x the proxy so the origin is never the bottleneck
BACKEND_MEM=1g

# --- the ramp: identical for every proxy (hard invariant) -------------------
# The load generator is loadgen/zrk (open-loop, coordinated-omission corrected).
# offered == start_rate + slope*t, so elapsed-time maps exactly to offered rate.
# It keeps offering at the scheduled rate past saturation (CO-safe), so the
# tipping point shows as a sharp knee.
MAX_RATE=160000       # req/s at the end of the linear ramp; calibrate so a
                      # backend-direct run saturates ABOVE this
RAMP_SECONDS=120      # ramp length (START_RATE -> MAX_RATE)
CONNECTIONS=2000      # open connections = in-flight concurrency cap (the open-loop
                      # guard; zrk keeps one request in flight per connection). Too
                      # high and past saturation it piles connections and collapses
                      # the path; ~2000 sits at the proxy sweet spot and plateaus
                      # cleanly. Keep it under zoxy's per-process relay-buffer cap
                      # x PROXY_CPUS (1024 x cores).
#THREADS=             # zrk worker threads (default: loadgen nproc)
REQ_PATH=/1k          # /64 /1k /10k /100k

# --- run driver --------------------------------------------------------------
PROXIES="direct zoxy haproxy envoy traefik nginx pingora"   # L4 TCP passthroughs
                                             # (zoxy's libxev build is L4-only);
                                             # zoxy needs a Linux docker host
                                             # with io_uring (native arch is
                                             # fine — no emulation). pingora is
                                             # a Rust binary we build on the
                                             # Pingora framework (proxies/pingora)
COOLDOWN=8            # seconds between proxies (settle + scrape)

# --- zoxy build ---------------------------------------------------------------
ZOXY_REF=57b3f66ac5a14257c11308012ab4daa5c2072e75  # pinned SHA of zoxy-io/zoxy
                      # (repinned 2026-07-15; the libxev rewrite: L4-only, no DNS).
                      # Pin a SHA — the Dockerfile caches the git clone, so "main"
                      # would silently be a stale commit.
#RELAY_BUFFERS_MAX=   # OPTIONAL benchmark override of zoxy's per-process L4
                      # concurrency cap (compile-time relay-buffer pool; upstream
                      # default 1024, patched at build time — image tag records
                      # it). Ceiling ~1634 before the io_uring ring-budget assert
                      # fails to compile.

# --- cloud only (filled by scripts/zrk-bench.sh) ------------------------------
#PROM_TARGETS=cloud
#BACKEND_IP=10.10.0.6
#PROXY_IP=10.10.0.34
#PROXY_CPUSET=0-3
