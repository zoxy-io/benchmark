# Copy to .env and adjust. Everything has a sane local default; the cloud
# entries are written by scripts/cloud-run.sh from terraform outputs.

# --- the fairness box: identical for every proxy (hard invariant) -----------
PROXY_CPUS=1          # must match the thread knobs (nbthread/--concurrency/GOMAXPROCS).
                      # 1 by default: zoxy (libxev) is single-threaded with no
                      # knob, so one core each keeps the face-off per-core fair;
                      # raise it to probe multi-core scaling (zoxy stays at 1)
PROXY_MEM=512m
BACKEND_CPUS=4        # >=2x the proxy so the origin is never the bottleneck
BACKEND_MEM=1g

# --- the ramp: identical for every proxy (hard invariant) -------------------
# elapsed-time == offered-rate only holds if ALL proxies get the same ramp.
MAX_RATE=20000        # req/s at the end of the linear ramp; calibrate: a
                      # backend-direct run must saturate ABOVE this
RAMP_DURATION=8m
WARM_RATE=100         # 30s constant warmup, discarded by the report
MAX_VUS=800           # backpressure guardrail: k6 drops iterations instead of
                      # opening unbounded connections when the proxy stalls.
                      # CEILING: warmup(200) + MAX_VUS must stay < 1024 — zoxy
                      # (libxev) holds one relay buffer per open tunnel and the
                      # pool is a compile-time 1024; more idle keep-alive VU
                      # conns than that get shed (EOF) at ANY offered rate
REQ_PATH=/1k          # /64 /1k /10k /100k

# --- run driver --------------------------------------------------------------
PROXIES="zoxy haproxy envoy traefik caddy"   # all run as L4 TCP passthroughs
                                             # (zoxy's libxev build is L4-only);
                                             # zoxy needs a Linux docker host
                                             # with io_uring (native arch is
                                             # fine — no emulation)
COOLDOWN=60           # seconds between proxies (TIME_WAIT drain, scrape settle)

# --- zoxy build ---------------------------------------------------------------
ZOXY_REF=libxev       # git ref of github.com/zoxy-io/zoxy to benchmark (the
                      # libxev rewrite: L4-only, single-threaded, no DNS)

# --- cloud only (filled by scripts/cloud-run.sh) ------------------------------
#PROM_TARGETS=cloud
#BACKEND_IP=10.10.0.20
#PROXY_IP=10.10.0.10
#PROXY_CPUSET=0-3
