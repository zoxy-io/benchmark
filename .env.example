# Copy to .env and adjust. Everything has a sane default; the cloud entries are
# written by scripts/zrk-bench.sh from terraform outputs.

# --- the fairness box: identical for every proxy (hard invariant) -----------
# Every proxy is hard-capped to 1 CPU (one thread/process) and pinned to core 0
# by the cloud overlay — the thread knobs are hardcoded to 1 in each proxy's
# config, so there is no PROXY_CPUS knob.
PROXY_MEM=512m
BACKEND_CPUS=4        # >=2x the proxy so the origin is never the bottleneck
BACKEND_MEM=1g

# --- the ramp: identical for every proxy (hard invariant) -------------------
# The load generator is loadgen/zrk (open-loop, coordinated-omission corrected).
# offered == start_rate + slope*t, so elapsed-time maps exactly to offered rate.
# It keeps offering at the scheduled rate past saturation (CO-safe), so the
# tipping point shows as a sharp knee.
MAX_RATE=67000        # req/s at the end of the linear ramp; ~the cross-VM
                      # network ceiling (the direct baseline clean-saturates ~60-65k)
RAMP_SECONDS=300      # ramp length START_RATE -> MAX_RATE (5 min: gentle slope,
                      # less warmup lag, finer per-offered-level resolution)
CONNECTIONS=500       # open connections = in-flight concurrency cap (the open-loop
                      # guard; zrk keeps one request in flight per connection). 500 is
                      # the sweet spot: past every proxy's throughput peak (~200-400
                      # conns) but before the high-concurrency congestion COLLAPSE the
                      # sweep exposed — haproxy/nginx do WORSE at 1024 than here — while
                      # saturating zoxy's ~43k/1-CPU ceiling (~11ms => ~470 conns,
                      # Little's law), well under its conn_slots default (1386 on the
                      # #61+ build; older builds capped ~1020 and churned at/over it).
TIMEOUT_S=1           # per-request WIRE timeout (bytes-out -> bytes-in). A hung-
                      # connection guard, NOT a CO-tail bound: past saturation a
                      # request waits for a free connection but completes fast once
                      # it has one, so it never trips the timeout while its
                      # scheduled->response latency balloons. Latency fairness is a
                      # REPORT concern — p50/p99 are read at a common sub-knee
                      # reference rate (report REF_RATE, default 2000 rps); overload
                      # shows as achieved-shortfall (shed), not errors.
REQ_PATH=/1k          # /64 /1k /10k /100k

# --- run driver --------------------------------------------------------------
PROXIES="direct zoxy haproxy envoy traefik nginx pingora"   # L7 HTTP reverse proxies
                                             # (zoxy phase-1 adds an `http`
                                             # listener); zoxy needs a Linux
                                             # docker host with io_uring (native
                                             # arch is fine — no emulation).
                                             # pingora is a Rust binary we build
                                             # on the Pingora framework
                                             # (proxies/pingora)
COOLDOWN=8            # seconds between proxies (settle + scrape)

# --- zoxy build ---------------------------------------------------------------
ZOXY_REF=2acaddde5c5e447ebd7e49623c14961ad97606f5  # pinned SHA of zoxy-io/zoxy
                      # v0.0.2 release (conn_slots default 1386/max 9621 + cq_fill_eighths tunable; #60 admin metrics; L7 HTTP: `http` listener, keep-alive both
                      # legs, upstream pool; no DNS). Pin a SHA — the Dockerfile
                      # caches the git clone, so a branch name like "phase-1"
                      # would silently be a stale commit.
#RELAY_BUFFERS_MAX=   # OPTIONAL, L4-LEGACY: override of zoxy's per-process L4
                      # relay-buffer cap. Does NOT apply to the phase-1 L7 path
                      # (bounded by conn_slots_max ~1020 + the upstream pool), and
                      # the build-time sed fails loudly against a phase-1 ref
                      # because the decl is no longer a numeric literal. Leave
                      # empty for L7 runs.

# --- cloud only (filled by scripts/zrk-bench.sh) ------------------------------
#PROM_TARGETS=cloud
#BACKEND_IP=10.10.0.6
#PROXY_IP=10.10.0.34
