{
  "uid": "proxy-bench-live-zrk",
  "title": "Proxy bench \u2014 live run (zrk open-loop)",
  "description": "Watch a ramp as it runs. Cross-proxy comparison lives in the HTML report (make report), not here.",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "testid",
        "label": "run",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(zrk_achieved_rps, testid)",
        "refresh": 2,
        "sort": 4
      },
      {
        "name": "proxy",
        "label": "proxy",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(zrk_achieved_rps{testid=~\"$testid\"}, proxy)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Achieved req/s per proxy (zrk)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (proxy) (zrk_achieved_rps{testid=~\"$testid\", proxy=~\"$proxy\"})",
          "legendFormat": "{{proxy}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latency (p50 / p90 / p99 / p99.9)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (proxy) (zrk_latency_seconds{testid=~\"$testid\", proxy=~\"$proxy\", quantile=\"0.5\"})",
          "legendFormat": "{{proxy}} p50"
        },
        {
          "refId": "B",
          "expr": "max by (proxy) (zrk_latency_seconds{testid=~\"$testid\", proxy=~\"$proxy\", quantile=\"0.9\"})",
          "legendFormat": "{{proxy}} p90"
        },
        {
          "refId": "C",
          "expr": "max by (proxy) (zrk_latency_seconds{testid=~\"$testid\", proxy=~\"$proxy\", quantile=\"0.99\"})",
          "legendFormat": "{{proxy}} p99"
        },
        {
          "refId": "D",
          "expr": "max by (proxy) (zrk_latency_seconds{testid=~\"$testid\", proxy=~\"$proxy\", quantile=\"0.999\"})",
          "legendFormat": "{{proxy}} p99.9"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Errors & offered-shortfall (saturation signals)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (proxy) (zrk_errors_ratio{testid=~\"$testid\", proxy=~\"$proxy\"})",
          "legendFormat": "{{proxy}} error ratio"
        },
        {
          "refId": "B",
          "expr": "sum by (proxy) (zrk_offered_rps{testid=~\"$testid\", proxy=~\"$proxy\"} - zrk_achieved_rps{testid=~\"$testid\", proxy=~\"$proxy\"})",
          "legendFormat": "{{proxy}} shortfall"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Proxy container CPU (cores)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"zoxy|haproxy|envoy|traefik|nginx|pingora\"}[15s]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Proxy container memory (working set)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (name) (last_over_time(container_memory_working_set_bytes{name=~\"zoxy|haproxy|envoy|traefik|nginx|pingora\"}[15s]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Host CPU busy % by role (excl. iowait; validity: loadgen/backend must have headroom)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - avg by (role) (rate(node_cpu_seconds_total{mode=~\"idle|iowait\"}[30s])))",
          "legendFormat": "{{role}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "zoxy \u2014 throughput (its own counters): accepts/s & L7 responses/s",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(zoxy_l7_responses[30s])",
          "legendFormat": "L7 responses/s"
        },
        {
          "refId": "B",
          "expr": "rate(zoxy_accepted[30s])",
          "legendFormat": "accepted conns/s"
        },
        {
          "refId": "C",
          "expr": "rate(zoxy_completed[30s])",
          "legendFormat": "completed/s"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "zoxy \u2014 admission shedding (flat 0 = no conn-slot pressure; spikes = at the cap)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(zoxy_shed_conn_slots[30s])",
          "legendFormat": "shed conn_slots/s"
        },
        {
          "refId": "B",
          "expr": "rate(zoxy_shed_relay_buffers[30s])",
          "legendFormat": "shed relay_buffers/s"
        },
        {
          "refId": "C",
          "expr": "rate(zoxy_shed_draining[30s])",
          "legendFormat": "shed draining/s"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "enable": true,
        "hide": false,
        "iconColor": "semi-dark-orange",
        "name": "Proxy pass",
        "expr": "sum(zrk_achieved_rps{testid=~\"$testid\"}) by (proxy)",
        "step": "15s",
        "tagKeys": "proxy",
        "titleFormat": "{{proxy}}",
        "textFormat": "{{proxy}} pass",
        "useValueForTime": false
      }
    ]
  }
}