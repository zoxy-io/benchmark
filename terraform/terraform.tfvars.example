# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

service_account_key_file = "sa-key.json"                # yc iam key create ... --output sa-key.json
cloud_id                 = "b1gxxxxxxxxxxxxxxxxx"
folder_id                = "b1gxxxxxxxxxxxxxxxxx"
zone                     = "ru-central1-a"

# From `make image` (it prints the URL after uploading the qcow2 to your bucket):
image_source_url = "https://storage.yandexcloud.net/YOUR-BUCKET/zoxy-benchmark/nixos.qcow2"

ssh_public_key   = "ssh-ed25519 AAAA... you@host"
allowed_ssh_cidr = "0.0.0.0/0"   # narrow to YOUR.IP/32

# Fleet sizing (all core_fraction=100). Defaults are a sensible first run:
# proxy 8c/16g, 1× loadgen 8c/16g, 2× backend 4c/8g, control 2c/4g.
proxy_cores    = 8
loadgen_count  = 1
backend_count  = 2
