# Rendered by the orchestrator from the terraform inventory, then scp'd to the
# control host as /etc/prometheus/prometheus.yml.
#   @@NODE_TARGETS@@ -> "ip:9100","ip:9100",...  (every host)
#   @@PROXY_IP@@     -> the proxy host's internal IP (for zoxy's own /metrics)
global:
  scrape_interval: 5s
  evaluation_interval: 5s

scrape_configs:
  - job_name: node
    static_configs:
      - targets: [@@NODE_TARGETS@@]

  # zoxy's Prometheus-style admin counters. The other proxies expose their own
  # (envoy :9902/stats/prometheus, traefik, caddy) — add jobs here if you want
  # to cross-check the proxy's self-reported numbers against node_exporter.
  - job_name: zoxy
    static_configs:
      - targets: ["@@PROXY_IP@@:9901"]
