# Rendered at deploy time: the upstream list (space-separated IP:9000) is filled in.
# auto_https off because we supply an explicit fixture cert; :8443 serves h2 by
# default. GOMAXPROCS defaults to all cores. Admin API off to keep it off the path.
{
	admin off
	auto_https off
}

:8080 {
	reverse_proxy @@BACKENDS@@ {
		lb_policy round_robin
	}
}

:8443 {
	tls /etc/bench/tls/cert.pem /etc/bench/tls/key.pem
	reverse_proxy @@BACKENDS@@ {
		lb_policy round_robin
	}
}
