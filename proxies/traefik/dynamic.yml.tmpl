# Rendered at deploy time: the origin server list (- url: "http://IP:9000") is
# filled in below. One service, two routers (plaintext + TLS). TLS negotiates h2 via ALPN.
http:
  routers:
    r-plain:
      rule: "PathPrefix(`/`)"
      entryPoints: [plain]
      service: origin
    r-tls:
      rule: "PathPrefix(`/`)"
      entryPoints: [tls]
      service: origin
      tls: {}
  services:
    origin:
      loadBalancer:
        passHostHeader: true
        servers:
@@BACKENDS@@

tls:
  certificates:
    - certFile: /etc/bench/tls/cert.pem
      keyFile: /etc/bench/tls/key.pem
  stores:
    default:
      defaultCertificate:
        certFile: /etc/bench/tls/cert.pem
        keyFile: /etc/bench/tls/key.pem
